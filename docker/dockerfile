FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS base
ARG APP_HOME=/app

FROM base AS deps
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR ${APP_HOME}

RUN apt-get update && apt-get install -y \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock ./

RUN uv sync --frozen --no-dev

FROM base AS build
WORKDIR ${APP_HOME}

COPY . .

FROM base AS run
WORKDIR ${APP_HOME}

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PATH="/app/.venv/bin:$PATH"

RUN apt-get update && apt-get install -y \
    postgresql-client \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN addgroup --system --gid 999 django && \
    adduser --system --uid 999 --gid 999 django

# Copy venv and strip unnecessary files
COPY --from=deps /app/.venv /app/.venv
RUN find /app/.venv -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true && \
    find /app/.venv -type f -name '*.pyc' -delete && \
    find /app/.venv -type f -name '*.pyo' -delete && \
    find /app/.venv -type f -name '*.dist-info/RECORD' -delete

# Copy entrypoint scripts
COPY --from=build --chown=django:django /app/docker/entrypoint.sh .
COPY --from=build --chown=django:django /app/docker/entrypoint-celery.sh .

# Copy Django application
COPY --from=build --chown=django:django /app/manage.py .
COPY --from=build --chown=django:django /app/clapp_backend ./clapp_backend
COPY --from=build --chown=django:django /app/conf ./conf
COPY --from=build --chown=django:django /app/applications ./applications
COPY --from=build --chown=django:django /app/organisations ./organisations
COPY --from=build --chown=django:django /app/performances ./performances
COPY --from=build --chown=django:django /app/profiles ./profiles
COPY --from=build --chown=django:django /app/services ./services
COPY --from=build --chown=django:django /app/support ./support


RUN chmod +x /app/entrypoint.sh /app/entrypoint-celery.sh

USER django

EXPOSE 8000

ENTRYPOINT [ "/app/entrypoint.sh" ]